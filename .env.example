# =============================================================================
# OSINT Earth Platform - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL ---
# In Docker Compose the hostname is "postgres". If you run `node backend` on your PC with Postgres in Docker, use:
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_HOST=postgres
#POSTGRES_PORT=5432
POSTGRES_DB=osint_earth
POSTGRES_USER=osint
POSTGRES_PASSWORD=changeme_postgres_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=osint_minio
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET_TILES=tiles
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_EXPORTS=exports

# --- Backend API ---
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=changeme_jwt_secret
# Must list every browser origin you use (port matters). Same-origin /api needs this only if you call :3001 directly.
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# --- Frontend (repo-root .env; vite.config.js envDir: "..") ---
# Leave VITE_API_URL and VITE_WS_URL empty so API + Socket.io use the same host/port as the page:
#   npm run dev → Vite proxies /api and /socket.io to localhost:3001
#   Docker :5173 or main nginx :80 → nginx proxies /api and /socket.io to the backend
# Set only for a split deployment, e.g. VITE_API_URL=http://localhost:3001
VITE_API_URL=
VITE_WS_URL=
# Cesium Ion: https://ion.cesium.com/tokens — if you set "Allowed URLs" on the token, add each UI origin, e.g.
#   http://localhost:5173  http://localhost  http://127.0.0.1:5173
VITE_CESIUM_ION_TOKEN=
# Docker SPA: same vars are passed as frontend build args; rebuild after changing them (nginx runtime env is not enough).

# --- AI Service (for anomaly scan from UI) ---
AI_SERVICE_URL=http://localhost:8000

# --- Data Source API Keys ---
# OpenSky Network (https://opensky-network.org) - aircraft tracking
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# NASA FIRMS (https://firms.modaps.eosdis.nasa.gov) - wildfire detection
FIRMS_MAP_KEY=

# ACLED (https://acleddata.com) - conflict events
ACLED_API_KEY=
ACLED_EMAIL=

# AISStream.io (https://aisstream.io) - global ship tracking (free)
AISSTREAM_API_KEY=

# Windy Webcams (https://api.windy.com) - global webcam feeds
WINDY_API_KEY=

# OpenWebcamDB (https://openwebcamdb.com) - additional webcam data
OPENWEBCAMDB_API_KEY=

# Copernicus / Sentinel Hub - satellite imagery
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# --- Notifications (news-feed digest, no duplicates) ---
# Telegram **bot** (outbound digest only — not channel ingest): @BotFather, then chat ID(s)
# Get chat ID by messaging your bot and visiting https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789,987654321
# NOTIFICATION_DIGEST_MINUTES=15  # Batch interval (10–30 min)
# APP_URL=http://localhost:5173  # Map URL for Telegram digest links (?event=ID opens that event on the globe)

# --- Telegram channel ingest (Pyrogram / docker service `telegram-ingest`) ---
# Required: https://my.telegram.org/apps
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=your_hash_string
# Session (pick one — required for `docker compose up -d` without a TTY):
#   A) TELEGRAM_SESSION_STRING=...   # from: cd workers && pip install -r requirements-telegram.txt && python -m telegram_ingest.export_session
#   B) Or run once: cd infrastructure && docker compose run --rm -it telegram-ingest  (saves .session file in volume)
# TELEGRAM_SESSION_NAME=osint_telegram
# TELEGRAM_WORKDIR=/data
# TELEGRAM_INGEST_ENABLED=false   # set to disable ingest container skip path
# TELEGRAM_GEO_MIN_CONFIDENCE=0.25
# On startup, fetch channel history this many days back (0 = skip). Capped at 365. Increase for deeper backfill.
# TELEGRAM_HISTORY_DAYS=5
# Translation during backfill is off by default (faster). Set true to call LibreTranslate for historical posts too.
# TELEGRAM_HISTORY_TRANSLATE=false
# TELEGRAM_GEO_FETCH_URLS=false
# TELEGRAM_GEO_DOMAIN_ALLOWLIST=example.com,reuters.com
# TELEGRAM_CHANNELS_CONFIG=/app/config/telegram_channels.yaml   # in-container; compose mounts workers/config/telegram_channels.yaml

# --- Translation (optional, for multi-language news) ---
# LibreTranslate API URL - default uses public instance
# LIBRETRANSLATE_URL=https://libretranslate.com

# --- Worker Configuration ---
WORKER_LOG_LEVEL=INFO
SATELLITE_POLL_HOURS=6
AIRCRAFT_POLL_SECONDS=30
SHIP_POLL_SECONDS=120
WILDFIRE_POLL_MINUTES=15
EARTHQUAKE_POLL_MINUTES=5
WEBCAM_POLL_HOURS=24
# GDELT event worker: how often the job runs (first fetch can take up to this long after workers start).
EVENT_POLL_MINUTES=60
This token must be submitted with each request as an HTTP header named x-ucdp-access-token. For example, using curl:
# This token must be submitted with each request as an HTTP header named x-ucdp-access-token. For example, using curl:
# curl -H "x-ucdp-access-token: YOUR-TOKEN" "https://ucdpapi.pcr.uu.se/api/gedevents/25.1?pagesize=100"
# The workers read UCDP_ACCESS_TOKEN and send that header automatically; set it when your token is issued.
# UCDP_ACCESS_TOKEN=
# UCDP_API_BASE=https://ucdpapi.pcr.uu.se/api
# UCDP_API_VERSION=25.1
# UCDP_POLL_HOURS=24
# UCDP_SYNC_DAYS=14
# UCDP_PAGESIZE=500
# UCDP_MAX_PAGES_PER_RUN=40