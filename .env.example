# =============================================================================
# OSINT Earth Platform - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=osint_earth
POSTGRES_USER=osint
POSTGRES_PASSWORD=changeme_postgres_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=osint_minio
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET_TILES=tiles
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_EXPORTS=exports

# --- Backend API ---
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=changeme_jwt_secret
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend ---
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_CESIUM_ION_TOKEN=

# --- Data Source API Keys ---
# OpenSky Network (https://opensky-network.org) - aircraft tracking
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# NASA FIRMS (https://firms.modaps.eosdis.nasa.gov) - wildfire detection
FIRMS_MAP_KEY=

# ACLED (https://acleddata.com) - conflict events
ACLED_API_KEY=
ACLED_EMAIL=

# AISStream.io (https://aisstream.io) - global ship tracking (free)
AISSTREAM_API_KEY=

# Windy Webcams (https://api.windy.com) - global webcam feeds
WINDY_API_KEY=

# OpenWebcamDB (https://openwebcamdb.com) - additional webcam data
OPENWEBCAMDB_API_KEY=

# Copernicus / Sentinel Hub - satellite imagery
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# --- Translation (optional, for multi-language news) ---
# LibreTranslate API URL - default uses public instance
# LIBRETRANSLATE_URL=https://libretranslate.com

# --- Worker Configuration ---
WORKER_LOG_LEVEL=INFO
SATELLITE_POLL_HOURS=6
AIRCRAFT_POLL_SECONDS=30
SHIP_POLL_SECONDS=120
WILDFIRE_POLL_MINUTES=15
EARTHQUAKE_POLL_MINUTES=5
WEBCAM_POLL_HOURS=24
EVENT_POLL_MINUTES=60
